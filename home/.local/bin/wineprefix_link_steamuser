#!/usr/bin/env bash

usage() {
  cat <<EOF

Description:
  Links a steamuser directory to a directory in a wine prefix so it can be used to store savegames in one place.
  Old steamuser directory will be backuped next to the old one inside the prefix.
  Default directory can be configured via STEAMUSER_DIR env variable.

Usage:
  steamuser_link <prefix>
EOF
}

# Validate STEAMUSER_DIR
STEAMUSER_DIR="${STEAMUSER_DIR:-$HOME/.steamuser}"
if [[ ! -d "$STEAMUSER_DIR" ]]; then
  echo "ERROR: directory $STEAMUSER_DIR doesn't exist" >&2
  exit 1
fi

# Check arguments
if [[ "$#" -ne 1 ]]; then
  echo "ERROR: Wrong argument count" >&2
  usage
  exit 1
fi
PREFIX_DIR="$1"

# Validate prefix directory exists
if [[ ! -d "$PREFIX_DIR" ]]; then
  echo "ERROR: Wine prefix directory $PREFIX_DIR doesn't exist" >&2
  exit 1
fi

# Validate it's a Wine prefix (check for drive_c)
if [[ ! -d "$PREFIX_DIR/drive_c" ]]; then
  echo "ERROR: $PREFIX_DIR doesn't appear to be a valid Wine prefix (missing drive_c)" >&2
  exit 1
fi

PREFIX_STEAMUSER_DIR="$PREFIX_DIR/drive_c/users/steamuser"
PREFIX_STEAMUSER_BAK_DIR="$PREFIX_STEAMUSER_DIR.bak"

# Remove old symlink if it exists
if [[ -L "$PREFIX_STEAMUSER_DIR" ]]; then
  echo "Removing old symlink"
  rm -f "$PREFIX_STEAMUSER_DIR"
else
  # Handle existing steamuser directory
  if [[ -d "$PREFIX_STEAMUSER_DIR" ]]; then
    # Check if backup already exists
    if [[ -d "$PREFIX_STEAMUSER_BAK_DIR" ]]; then
      echo "WARNING: Backup directory $PREFIX_STEAMUSER_BAK_DIR already exists" >&2
      read -p "Remove existing backup? (y/N) " -n 1 -r
      echo
      if [[ $REPLY =~ ^[Yy]$ ]]; then
        rm -rf "$PREFIX_STEAMUSER_BAK_DIR"
      else
        echo "Aborting to prevent data loss" >&2
        exit 1
      fi
    fi
    
    echo "Moving existing steamuser directory to $PREFIX_STEAMUSER_BAK_DIR"
    mv "$PREFIX_STEAMUSER_DIR" "$PREFIX_STEAMUSER_BAK_DIR"
  fi
fi

# Create symlink
echo "Creating symlink from $STEAMUSER_DIR to $PREFIX_STEAMUSER_DIR"
ln -s "$STEAMUSER_DIR" "$PREFIX_STEAMUSER_DIR"

echo "Successfully linked steamuser directory"
